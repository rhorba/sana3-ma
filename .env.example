# Copy to .env and adjust for your environment. These are dev-safe defaults — DO NOT reuse in production.

# --- Database ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sana3
DB_USER=sana3
DB_PASSWORD=sana3_dev_password
# Host-machine port for connecting from outside Docker (e.g. psql, a GUI client) — remapped
# because 5432 is often already taken by a local Postgres install.
DB_HOST_PORT=5433

# --- Backend (Spring Boot) ---
SERVER_PORT=8080
# Host-machine port for the backend container — remapped because 8080 is often already taken.
BACKEND_HOST_PORT=8081
JWT_SECRET=dev-only-change-me-32-bytes-minimum-secret
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- Frontend (Angular) ---
API_BASE_URL=http://localhost:8080/api/v1
